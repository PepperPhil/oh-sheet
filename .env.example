# Copy to .env and fill in the values you need. .env is gitignored.
# Pydantic-settings loads this via env_prefix="OHSHEET_" from the repo root.

# --- Refine stage (LLM-driven score metadata) ---
# Anthropic API key — required when OHSHEET_REFINE_ENABLED=true (the default).
# Without it, the refine stage falls back to pass-through on every job.
OHSHEET_ANTHROPIC_API_KEY=

# Optional overrides — leave commented to use the defaults in backend/config.py.
# OHSHEET_REFINE_ENABLED=true
# OHSHEET_REFINE_MODEL=claude-sonnet-4-6
# OHSHEET_REFINE_MAX_SEARCHES=5
# OHSHEET_REFINE_BUDGET_SEC=300
# OHSHEET_REFINE_CALL_TIMEOUT_SEC=120

# --- Core infra ---
# OHSHEET_REDIS_URL=redis://localhost:6379/0
# OHSHEET_BLOB_ROOT=./blob
# OHSHEET_LOG_LEVEL=INFO
